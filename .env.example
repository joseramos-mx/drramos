# ─────────────────────────────────────────────────────────────
#  /diseno-sonrisa · variables de entorno
#
#  Copia este archivo como `.env.local` y completa con valores reales.
#  NUNCA pegues secretos (tokens, service keys) directamente aquí
#  porque .env.example queda en el repo público.
#
#  Variables sin prefijo NEXT_PUBLIC_ son solo server side.
# ─────────────────────────────────────────────────────────────


# ─── Persistencia del lead · Supabase (único destino) ──────────
# Project URL y anon key del proyecto de Supabase. La anon key es
# pública (va al bundle del browser), pero la tabla `leads` debe
# tener RLS que solo permita INSERT y nunca SELECT desde anon.
# Ver supabase/migrations/20260526000000_create_leads.sql
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ─── Meta Conversions API (server-side, dedupe con el Pixel) ───
# ID numérico del Pixel. Mismo que fbq('init', ...).
META_PIXEL_ID=27631678653096946

# Access token de la Conversions API. Se genera en Events Manager
# > Configuración > Conversions API > Generar token.
# REAL VALUE GOES IN .env.local, NEVER HERE.
META_CAPI_ACCESS_TOKEN=

# Código opcional para validar eventos en "Test events" antes de
# pasar a producción. Vacío en producción.
META_TEST_EVENT_CODE=


# ─── Meta Pixel (client-side, expuesto al browser) ─────────────
NEXT_PUBLIC_META_PIXEL_ID=27631678653096946
