# ─────────────────────────────────────────────────────────────
#  /diseno-sonrisa · variables de entorno
#
#  Copia este archivo como `.env.local` y completa con valores reales.
#  Nunca commitees `.env.local`.
#
#  Variables sin prefijo NEXT_PUBLIC_ son sólo server-side.
#  Si una variable falta, el route handler degrada con elegancia
#  (logs en consola) pero NO se persisten leads ni se dispara CAPI.
# ─────────────────────────────────────────────────────────────


# ─── Persistencia del lead (obligatorio en producción) ─────────
# Endpoint que recibe el lead. Puede ser:
#   - Webhook de n8n:   https://n8n.tudominio.com/webhook/diseno-sonrisa
#   - Función Supabase: https://xxx.functions.supabase.co/lead
#   - Endpoint de CRM:  https://api.tucrm.com/leads
# Sin esta variable el handler sólo loguea el lead a stdout (dev).
LEAD_WEBHOOK_URL=

# Bearer token opcional. Si lo defines, se envía como:
#   Authorization: Bearer <secret>
LEAD_WEBHOOK_SECRET=


# ─── Meta Conversions API (server-side, dedupe con el Pixel) ───
# ID numérico del Pixel de Meta. Mismo que se usa en fbq('init', ...).
META_PIXEL_ID=

# Access token de la Conversions API. Se genera en Events Manager
# > Configuración > Conversions API > Generar token.
META_CAPI_ACCESS_TOKEN=

# Código opcional para validar eventos en "Test events" de Events
# Manager antes de pasar a producción. Déjalo vacío en producción.
# Ej: TEST12345
META_TEST_EVENT_CODE=


# ─── Meta Pixel (client-side, opcional con prefijo público) ────
# Si quieres parametrizar el snippet de inicialización del Pixel en
# layout.js en vez de hardcodearlo, expónlo así. Cualquier var con
# prefijo NEXT_PUBLIC_ es visible en el bundle del navegador.
NEXT_PUBLIC_META_PIXEL_ID=
